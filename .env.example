# Laravel API base MUST end with /api/v1 (routes/api.php is mounted at /api, then v1 prefix).
#
# php artisan serve (port 8000):
#   EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
# Android emulator hitting PC localhost:
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:8000/api/v1
# Physical phone on Wi‑Fi (replace IP):
#   EXPO_PUBLIC_API_URL=http://192.168.1.46:8000/api/v1
#
# XAMPP (project at htdocs/amazepays — public is the web root):
#   EXPO_PUBLIC_API_URL=http://192.168.1.46/amazepays/public/api/v1
#
# Wrong examples that often cause 404: http://192.168.1.46/api/v1 (missing :8000 or /public path)
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1

# Optional crash reporting
EXPO_PUBLIC_SENTRY_DSN=

# Optional EAS project id (expo.dev)
EXPO_PUBLIC_EAS_PROJECT_ID=
